# API keys and secrets
.env
.env~

# Local-only project context (AGENT.md is the persona/status doc the
# AI assistant reads on session start; it's intentionally not
# version-controlled because it changes constantly and contains
# in-flight planning notes that don't belong in commit history).
AGENT.md

# Leftover test-workspace temp dirs created by extension tests via
# fs.mkdtempSync(path.join(tempHomeDir, 'gemini-cli-test-workspace-')).
# When tests crash mid-setup or tempHomeDir resolves to cwd, these
# scratch dirs leak into the repo root. Ignore them so a leak doesn't
# show up in `git status` or accidentally get committed.
gemini-cli-test-workspace*/

# gemini-cli settings
# We want to keep the .gemini in the root of the repo and ignore any .gemini
# in subdirectories. In our root .gemini we want to allow for version control
# for subcommands.
**/.gemini/
!/.gemini/
.gemini/*
!.gemini/config.yaml
!.gemini/commands/
!.gemini/skills/
!.gemini/settings.json

# Note: .gemini-clipboard/ is NOT in gitignore so Gemini can access pasted images

# Dependency directory
node_modules
bower_components

# Editors
.idea
*.iml

# OS metadata
.DS_Store
Thumbs.db

# TypeScript build info files
*.tsbuildinfo

# Ignore built ts files
dist

# Docker folder to help skip auth refreshes
.docker

bundle

# Test report files
junit.xml
packages/*/coverage/

# Generated files
packages/cli/src/generated/
packages/core/src/generated/
packages/devtools/src/_client-assets.ts
.integration-tests/
.perf-tests/
packages/vscode-ide-companion/*.vsix
packages/cli/download-ripgrep*/

# GHA credentials
gha-creds-*.json

# Log files
patch_output.log
gemini-debug.log

.genkit
.gemini-clipboard/
.eslintcache
evals/logs/

temp_agents/

# conductor extension and planning directories
conductor/
